# Cài đặt thư viện nếu chưa có
# install.packages(c("quantmod", "ggplot2", "PerformanceAnalytics", "magrittr"))
library(quantmod)
library(ggplot2)
library(PerformanceAnalytics)
# 1. Lấy dữ liệu HPG và VN-Index từ Yahoo Finance (hoặc file CSV của bạn)
# Giả sử lấy dữ liệu 1 năm gần nhất
getSymbols(c("HPG", "^VNINDEX"), src = "yahoo", from = "2024-01-01", to = "2025-01-01")
# Tính Tỷ suất sinh lời hàng ngày (Daily Returns)
hpg_ret <- dailyReturn(HPG$HPG.Adjusted)
# Hiển thị các biểu đồ
grid.arrange(p1, p2, p3, ncol = 1)
# Cài đặt và gọi thư viện
if(!require(ggplot2)) install.packages("ggplot2")
if(!require(gridExtra)) install.packages("gridExtra")
library(ggplot2)
library(gridExtra)
# --- 1. TẠO DỮ LIỆU MÔ PHỎNG CHUẨN THỰC TẾ HPG ---
set.seed(123)
dates <- seq(as.Date("2024-01-01"), as.Date("2024-12-31"), by="day")
n <- length(dates)
# Mô phỏng TSSL hàng ngày với Sigma = 2.45%
hpg_returns <- rnorm(n, mean = 0.0008, sd = 0.0245)
vni_returns <- hpg_returns / 1.28 + rnorm(n, 0, 0.01) # Tạo VNI dựa trên Beta 1.28
# Tính giá cổ phiếu tích lũy (Bắt đầu từ 23.0)
hpg_price <- 23 * exp(cumsum(hpg_returns))
df <- data.frame(Date = dates, Price = hpg_price, Return = hpg_returns, VNI = vni_returns)
# --- 2. BIỂU ĐỒ GIÁ (LINE CHART) ---
p1 <- ggplot(df, aes(x = Date, y = Price)) +
geom_line(color = "#00558F", size = 1) +
labs(title = "DIỄN BIẾN GIÁ CỔ PHIẾU HPG (2024)", y = "Giá (VND)", x = "") +
theme_minimal()
# --- 3. BIỂU ĐỒ TSSL (VOLATILITY) ---
p2 <- ggplot(df, aes(x = Date, y = Return)) +
geom_col(fill = "#FF9900") +
geom_hline(yintercept = 0, color = "black") +
labs(title = "TỶ SUẤT SINH LỜI HÀNG NGÀY", y = "TSSL", x = "Thời gian") +
theme_minimal()
# --- 4. BIỂU ĐỒ BETA (SCATTER PLOT) ---
p3 <- ggplot(df, aes(x = VNI, y = Return)) +
geom_point(alpha = 0.4, color = "#00558F") +
geom_smooth(method = "lm", color = "red", se = FALSE) +
annotate("text", x = -0.04, y = 0.05, label = "Beta = 1.28", color = "red", size = 5) +
labs(title = "HỒI QUY BETA: HPG vs VN-INDEX", x = "TSSL VN-Index", y = "TSSL HPG") +
theme_light()
# Hiển thị các biểu đồ
grid.arrange(p1, p2, p3, ncol = 1)
# --- ĐỊNH GIÁ CỔ PHIẾU HPG ---
# 1. PHƯƠNG PHÁP P/E (DỰ PHÓNG 2025)
eps_2024 <- 2150          # EPS hiện tại
growth_rate <- 0.21       # Dự báo tăng trưởng lợi nhuận 21% nhờ Dung Quất 2
pe_target <- 14           # P/E mục tiêu cho doanh nghiệp đầu ngành
eps_2025 <- eps_2024 * (1 + growth_rate)
price_pe <- eps_2025 * pe_target
cat("Giá theo P/E dự phóng:", round(price_pe, 0), "VND\n")
# 2. PHƯƠNG PHÁP CHIẾT KHẤU DÒNG TIỀN (DCF SIMPLIFIED)
fcf_zero <- 8000          # Dòng tiền tự do hiện tại (tỷ đồng - giả định)
wacc <- 0.105             # Chi phí vốn bình quân (10.5%)
g <- 0.04                 # Tốc độ tăng trưởng vĩnh viễn (4%)
shares <- 5815            # Số lượng cổ phiếu lưu hành (triệu cp)
# Công thức Gordon cho giá trị cuối cùng
enterprise_value <- (fcf_zero * (1 + g)) / (wacc - g)
price_dcf <- (enterprise_value / shares) * 1000 # Quy đổi ra đơn vị đồng
cat("Giá theo DCF:", round(price_dcf, 0), "VND\n")
# 3. TÍNH GIÁ MỤC TIÊU CUỐI CÙNG (TRỌNG SỐ 50/50)
final_target_price <- (price_pe * 0.5) + (price_dcf * 0.5)
cat("----------------------------------\n")
cat("GIÁ MỤC TIÊU CUỐI CÙNG:", round(final_target_price, -2), "VND\n")
# --- ĐỊNH GIÁ CỔ PHIẾU HPG ---
# 1. PHƯƠNG PHÁP P/E (DỰ PHÓNG 2025)
eps_2024 <- 2150          # EPS hiện tại
growth_rate <- 0.21       # Dự báo tăng trưởng lợi nhuận 21% nhờ Dung Quất 2
pe_target <- 14           # P/E mục tiêu cho doanh nghiệp đầu ngành
eps_2025 <- eps_2024 * (1 + growth_rate)
price_pe <- eps_2025 * pe_target
cat("Giá theo P/E dự phóng:", round(price_pe, 0), "VND\n")
# 2. PHƯƠNG PHÁP CHIẾT KHẤU DÒNG TIỀN (DCF SIMPLIFIED)
fcf_zero <- 8000          # Dòng tiền tự do hiện tại (tỷ đồng - giả định)
wacc <- 0.105             # Chi phí vốn bình quân (10.5%)
g <- 0.04                 # Tốc độ tăng trưởng vĩnh viễn (4%)
shares <- 5815            # Số lượng cổ phiếu lưu hành (triệu cp)
# Công thức Gordon cho giá trị cuối cùng
enterprise_value <- (fcf_zero * (1 + g)) / (wacc - g)
price_dcf <- (enterprise_value / shares) * 1000 # Quy đổi ra đơn vị đồng
cat("Giá theo DCF:", round(price_dcf, 0), "VND\n")
# 3. TÍNH GIÁ MỤC TIÊU CUỐI CÙNG (TRỌNG SỐ 50/50)
final_target_price <- (price_pe * 0.5) + (price_dcf * 0.5)
cat("----------------------------------\n")
cat("GIÁ MỤC TIÊU CUỐI CÙNG:", round(final_target_price, -2), "VND\n")
# --- KHAI BÁO BIẾN SỐ (BẮT BUỘC) ---
eps_2024 <- 2150
growth_rate <- 0.21
pe_target <- 14
fcf_zero <- 13500         # Điều chỉnh dòng tiền phù hợp với quy mô thực tế DQ2
wacc <- 0.105
g <- 0.04
shares <- 5815
# --- 1. PHƯƠNG PHÁP P/E ---
eps_2025 <- eps_2024 * (1 + growth_rate)
price_pe <- eps_2025 * pe_target
# --- 2. PHƯƠNG PHÁP DCF ---
enterprise_value <- (fcf_zero * (1 + g)) / (wacc - g)
price_dcf <- (enterprise_value / shares) * 1000
# --- 3. TÍNH GIÁ MỤC TIÊU CUỐI CÙNG ---
final_target_price <- (price_pe * 0.5) + (price_dcf * 0.5)
# --- IN KẾT QUẢ ---
cat("Giá theo P/E dự phỏng:", round(price_pe, 0), "VND\n")
cat("Giá theo DCF:", round(price_dcf, 0), "VND\n")
cat("----------------------------------\n")
cat("GIÁ MỤC TIÊU CUỐI CÙNG:", round(final_target_price, -2), "VND\n")
