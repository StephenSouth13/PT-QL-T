theme = chartTheme("white"), type = "line"
)
addTA(rsi14, col = "purple", lwd = 2)  # RSI panel
addTA(rep(70, NROW(x)), col = "red", lty = 2)  # overbought line
# =========================
# ADVANCED TECHNICAL ANALYSIS SCRIPT
# =========================
# install.packages(c("readxl","dplyr","xts","quantmod","TTR","openxlsx"))
library(readxl)
library(dplyr)
library(xts)
library(quantmod)
library(TTR)
library(openxlsx)
clear
install.packages("openxlsx")
# =========================
# ADVANCED TECHNICAL ANALYSIS SCRIPT
# =========================
# install.packages(c("readxl","dplyr","xts","quantmod","TTR","openxlsx"))
library(readxl)
library(dplyr)
library(xts)
library(quantmod)
library(TTR)
library(openxlsx)
# =========================
# 1) READ DATA
# =========================
file_path <- "D:/UEH/PT-QL-T/Buoi_5/Buoi_5/stock_prices (1).xlsx"
df <- read_excel(file_path, sheet = "Prices") %>%
mutate(Date = as.Date(Date)) %>%
arrange(Date)
# =========================
# 2) CONVERT TO XTS
# =========================
x <- xts(df[, c("Open","High","Low","Close","Volume")], order.by = df$Date)
colnames(x) <- c("Open","High","Low","Close","Volume")
# =========================
# 3) RETURNS
# =========================
ret_close <- dailyReturn(Cl(x), type = "arithmetic")
logret_close <- dailyReturn(Cl(x), type = "log")
# =========================
# 4) TECHNICAL INDICATORS
# =========================
# Moving Average
sma20 <- SMA(Cl(x), 20)
sma50 <- SMA(Cl(x), 50)
# Bollinger Bands
bb <- BBands(Cl(x), n = 20)
# RSI
rsi14 <- RSI(Cl(x), 14)
# MACD
macd_obj <- MACD(Cl(x), 12, 26, 9)
# =========================
# 5) EXPORT INDICATOR DATA
# =========================
indicator_data <- merge(
Cl(x),
sma20,
sma50,
bb$up,
bb$mavg,
bb$dn,
rsi14,
macd_obj
)
colnames(indicator_data) <- c(
"Close",
"SMA20",
"SMA50",
"BB_Upper",
"BB_Middle",
"BB_Lower",
"RSI14",
"MACD",
"MACD_Signal"
)
write.xlsx(
data.frame(Date=index(indicator_data), coredata(indicator_data)),
"technical_indicators.xlsx"
)
# =========================
# 6) CREATE OUTPUT FOLDER
# =========================
if(!dir.exists("output")){
dir.create("output")
}
# =========================
# 7) EXPORT CHART IMAGE
# =========================
png("output/technical_chart.png", width=1400, height=900)
chartSeries(
x,
type="candlesticks",
theme=chartTheme("white"),
name="Stock Technical Analysis"
)
# volume
addVo()
# moving averages
addTA(sma20, on=1, col="blue", lwd=2)
addTA(sma50, on=1, col="red", lwd=2)
# bollinger bands
addBBands()
# MACD
addMACD()
# RSI
addRSI()
dev.off()
# =========================
# 8) QUICK VIEW
# =========================
tail(indicator_data,5)
