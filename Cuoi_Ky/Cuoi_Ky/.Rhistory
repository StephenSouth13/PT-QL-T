library(quantmod)
library(xts)
library(PerformanceAnalytics)
library(tseries)
symbols <- c("FPT.VN", "VCB.VN", "HPG.VN", "VNM.VN", "MSN.VN")
getSymbols(symbols, src = "yahoo", from = "2024-04-10", to = "2026-04-10")
tryCatch({
getSymbols("^VNI", src = "yahoo", from = "2024-04-10", to = "2026-04-10")
}, error = function(e) {
print("Lỗi tải ^VNI, vui lòng kiểm tra kết nối hoặc dùng file CSV thay thế.")
})
getSymbols("^VNINDEX.VN", src = "yahoo", from = "2024-04-10", to = "2026-04-10")
View(fpt_data)
# Làm sạch dữ liệu FPT (loại bỏ các dòng NA bạn thấy trong hình)
fpt_clean <- na.omit(fpt_data)
# 1. Tính log return [cite: 8]
R_fpt <- diff(log(Cl(fpt_clean)))
R_fpt <- na.omit(R_fpt)
# 2. Vẽ đồ thị PTKT với đầy đủ các chỉ báo theo đề bài
chartSeries(fpt_clean, theme = chartTheme("white"), name = "Phân tích kỹ thuật FPT")
addSMA(n = 5, col = "blue")   # SMA(5)
addSMA(n = 20, col = "red")   # SMA(20)
addMACD(fast = 12, slow = 26, signal = 9) # MACD
addBBands(n = 20, sd = 2)    # Bollinger Bands
addRSI(n = 14)               # RSI
prices <- merge(Cl(FPT.VN), Cl(VCB.VN), Cl(HPG.VN), Cl(VNM.VN), Cl(MSN.VN))
colnames(prices) <- c("FPT", "VCB", "HPG", "VNM", "MSN")
R_all <- na.omit(diff(log(prices))) # [cite: 8]
View(fpt_clean)
mu <- colMeans(R_all) # Mean [cite: 17]
sd_v <- apply(R_all, 2, sd) # SD [cite: 18]
var_v <- apply(R_all, 2, var) # Variance [cite: 20]
# 3. Tính Skewness & Kurtosis (Đúng công thức tài liệu) [cite: 35, 41]
skew_v <- apply(R_all, 2, function(x) {
m <- mean(x); s <- sd(x); mean((x - m)^3)/(s^3)
})
kurt_v <- apply(R_all, 2, function(x) {
m <- mean(x); s <- sd(x); mean((x - m)^4)/(s^4) - 3
})
# In kết quả ra màn hình để chép vào file Excel/Word
stats_summary <- rbind(mu, sd_v, var_v, skew_v, kurt_v)
round(stats_summary, 6) # [cite: 32, 46]
# 4. Vẽ Histogram cho FPT để nhận xét tính chuẩn [cite: 53]
hist(R_all[, "FPT"], breaks = 50, main = "Phân phối lợi nhuận FPT", col = "skyblue", xlab = "Log Return")
# Xuất các file báo cáo
png("Ket_Qua_PTKT_PFT.png", width = 800,height = 600)
# Chạy lệnh vẽ (Phải chạy lại lệnh vẽ sau khi mở png)
chartSeries(fpt_clean, theme = chartTheme("white"), name = "PTKT FPT")
addSMA(n = 5); addSMA(n = 20); addMACD(); addBBands(); addRSI()
# Đóng file để hoàn tất việc lưu
dev.off()
png("Histogram_FPT.png", width = 600, height = 400)
hist(R_all[, "FPT"], breaks = 50, main = "Phân phối lợi nhuận FPT", col = "skyblue")
dev.off()
# Tạo bảng thống kê
stats_table <- data.frame(
Mean = mu,
SD = sd_v,
Variance = var_v,
Skewness = skew_v,
Kurtosis = ex_kurt_v
)
# Tạo bảng thống kê
stats_table <- data.frame(
Mean = mu,
SD = sd_v,
Variance = var_v,
Skewness = skew_v,
Kurtosis = ex_kurt_v
)
# --- 1. TÍNH TOÁN CÁC CHỈ SỐ THỐNG KÊ (CÂU 2A) ---
mu <- colMeans(R_all)
sd_v <- apply(R_all, 2, sd)
var_v <- apply(R_all, 2, var)
# Tính Skewness
skew_v <- apply(R_all, 2, function(x) {
m <- mean(x); s <- sd(x); mean((x - m)^3)/(s^3)
})
# Định nghĩa ex_kurt_v (Excess Kurtosis) - Lệnh này sẽ sửa lỗi của bạn
ex_kurt_v <- apply(R_all, 2, function(x) {
m <- mean(x); s <- sd(x); mean((x - m)^4)/(s^4) - 3
}) [cite: 40-45]
# --- 1. TÍNH TOÁN CÁC CHỈ SỐ THỐNG KÊ (CÂU 2A) ---
mu <- colMeans(R_all)
sd_v <- apply(R_all, 2, sd)
var_v <- apply(R_all, 2, var)
skew_v <- apply(R_all, 2, function(x) {
m <- mean(x); s <- sd(x); mean((x - m)^3)/(s^3)
})
ex_kurt_v <- apply(R_all, 2, function(x) {
m <- mean(x); s <- sd(x);
mean((x - m)^4)/(s^4) - 3
})
# --- 2. XUẤT FILE EXCEL (CSV) ĐỂ NỘP BÀI ---
stats_table <- data.frame(
Mean = mu,
Standard_Deviation = sd_v,
Variance = var_v,
Skewness = skew_v,
Excess_Kurtosis = ex_kurt_v
)
write.csv(stats_table, "Bao_cao_Thong_ke_5_ma.csv") [cite: 32]
stats_table <- data.frame(
Mean = mu,
Standard_Deviation = sd_v,
Variance = var_v,
Skewness = skew_v,
Excess_Kurtosis = ex_kurt_v
)
write.csv(stats_table, "Bao_cao_Thong_ke_5_ma.csv")
png("Histogram_FPT.png", width = 800, height = 600)
hist(R_all[, "FPT"], breaks = 50,
main = "Phân phối lợi nhuận FPT",
col = "skyblue", xlab = "Log Return", border = "white")
dev.off() # Lệnh này bắt buộc phải có để đóng file ảnh
png("PTKT_FPT.png", width = 1000, height = 800)
chartSeries(fpt_clean, theme = chartTheme("white"), name = "Phân tích kỹ thuật FPT")
addSMA(n = 5, col = "blue")
addSMA(n = 20, col = "red")
addMACD(fast = 12, slow = 26, signal = 9)
addBBands(n = 20, sd = 2)
addRSI(n = 14)
dev.off()
# 1. Tính Ma trận Hiệp phương sai và Tương quan
print(Sigma <- cov(R_all))
print(Corr_mat <- cor(R_all))
# 2. Tính MVP cho FPT và VCB
v1 <- Sigma["FPT", "FPT"]; v2 <- Sigma["VCB", "VCB"]; c12 <- Sigma["FPT", "VCB"]
w_fpt_mvp <- (v2 - c12) / (v1 + v2 - 2*c12)
print(paste("Tỷ trọng FPT trong MVP là:", round(w_fpt_mvp, 4)))
# 3. Chạy CAPM (Giả sử bạn đã có Rm)
model_fpt <- lm((R_all[,"FPT"] - rf_daily) ~ (Rm - rf_daily))
print(Sigma <- cov(R_all))
print(Corr_mat <- cor(R_all))
v1 <- Sigma["FPT", "FPT"]; v2 <- Sigma["VCB", "VCB"]; c12 <- Sigma["FPT", "VCB"]
w_fpt_mvp <- (v2 - c12) / (v1 + v2 - 2*c12)
print(paste("Tỷ trọng FPT trong MVP là:", round(w_fpt_mvp, 4)))
model_fpt <- lm((R_all[,"FPT"] - rf_daily) ~ (Rm - rf_daily))
# 1. Khai báo lãi suất phi rủi ro (Giả sử 3%/năm theo tài liệu thực hành)
rf_annual <- 0.03
rf_daily  <- rf_annual / 250
# 2. Định nghĩa Rm (Lợi nhuận thị trường - trung bình của 5 mã nếu chưa có VNIndex)
Rm <- rowMeans(R_all)
# 3. Chạy lại lệnh hồi quy (Bây giờ sẽ không còn lỗi)
model_fpt <- lm((R_all[,"FPT"] - rf_daily) ~ (Rm - rf_daily))
rf_annual <- 0.03
rf_daily  <- rf_annual / 250
Rm <- rowMeans(R_all)
model_fpt <- lm((R_all[,"FPT"] - rf_daily) ~ (Rm - rf_daily))
FPT_excess <- R_all
# Việc tạo biến riêng giúp đảm bảo độ dài (length) các vector khớp nhau 100%
FPT_excess <- R_all[, "FPT"] - rf_daily
Market_excess <- Rm - rf_daily
# 3. Chạy hồi quy CAPM (Câu 2C)
model_fpt <- lm(FPT_excess ~ Market_excess)
# 4. Xem kết quả
summary(model_fpt)
