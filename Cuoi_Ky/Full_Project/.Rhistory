# --- 6. PHÂN TÍCH ĐỐI CHIẾU ĐA TÀI SẢN (BỔ SUNG CHO ĐỀ ÁN) ---
# 1. Biểu đồ Barplot so sánh rủi ro (SD) của 5 ngành
# Mục tiêu: Minh chứng cho tính đa dạng hóa của danh mục
png("Comparison_Risk.png", width = 800, height = 600)
barplot(sd_v * sqrt(250), # Chuẩn hóa theo năm cho dễ nhìn
col = c("blue", "green", "red", "orange", "purple"),
main = "So sánh Rủi ro (Độ lệch chuẩn năm) giữa các mã",
ylab = "Volatility (Annualized)",
las = 1)
# ==============================================================================
# ĐỀ ÁN CÁ NHÂN CUỐI KỲ - TÀI CHÍNH ĐỊNH LƯỢNG
# Sinh viên thực hiện: [Tên Anh Kiên]
# ==============================================================================
library(quantmod)
library(xts)
library(PerformanceAnalytics)
library(tseries)
# --- 1. CHUẨN BỊ DỮ LIỆU ---
# Danh mục mới: TCB, MWG, REE, GAS, HPG
symbols <- c("TCB.VN", "MWG.VN", "REE.VN", "GAS.VN", "HPG.VN")
getSymbols(symbols, src = "yahoo", from = "2024-04-10", to = "2026-04-10")
# Làm sạch dữ liệu TCB cho Câu 1
tcb_data <- na.omit(TCB.VN)
R_tcb <- na.omit(diff(log(Cl(tcb_data))))
# --- 2. CÂU 1: PHÂN TÍCH KỸ THUẬT TCB ---
png("PTKT_TCB.png", width = 1000, height = 800)
chartSeries(tcb_data, theme = chartTheme("white"), name = "Phân tích kỹ thuật TCB - Techcombank")
addSMA(n = 5, col = "blue")
addSMA(n = 20, col = "red")
addMACD(fast = 12, slow = 26, signal = 9)
addBBands(n = 20, sd = 2)
addRSI(n = 14)
dev.off()
# --- 3. CÂU 2A: THỐNG KÊ MÔ TẢ ---
prices <- merge(Cl(TCB.VN), Cl(MWG.VN), Cl(REE.VN), Cl(GAS.VN), Cl(HPG.VN))
colnames(prices) <- c("TCB", "MWG", "REE", "GAS", "HPG")
R_all <- na.omit(diff(log(prices)))
# Tính toán chỉ số
mu <- colMeans(R_all)
sd_v <- apply(R_all, 2, sd)
skew_v <- apply(R_all, 2, function(x) skewness(x))
kurt_v <- apply(R_all, 2, function(x) kurtosis(x)) # Excess Kurtosis
stats_table <- data.frame(Mean = mu, SD = sd_v, Skewness = skew_v, Excess_Kurtosis = kurt_v)
write.csv(stats_table, "Thong_ke_AnhKien.csv")
png("Histogram_TCB.png", width = 800, height = 600)
hist(R_all[, "TCB"], breaks = 50, main = "Phân phối lợi nhuận TCB", col = "orange", border = "white")
dev.off()
# --- 4. CÂU 2B: MARKOWITZ (TCB & MWG) ---
Sigma <- cov(R_all)
Corr_mat <- cor(R_all)
v1 <- Sigma["TCB", "TCB"]; v2 <- Sigma["MWG", "MWG"]; c12 <- Sigma["TCB", "MWG"]
w_tcb_mvp <- (v2 - c12) / (v1 + v2 - 2*c12)
w5 <- rep(0.2, 5)
ERP5 <- sum(w5 * mu)
SDP5 <- sqrt(as.numeric(t(w5) %*% Sigma %*% w5))
# --- 5. CÂU 2C: CAPM ---
rf_daily <- 0.03 / 250
Rm <- rowMeans(R_all)
Market_excess <- Rm - rf_daily
TCB_excess <- R_all[, "TCB"] - rf_daily
model_tcb <- lm(TCB_excess ~ Market_excess)
# Vẽ SML
beta_all <- apply(R_all, 2, function(x) cov(x - rf_daily, Market_excess) / var(Market_excess))
png("SML_AnhKien.png", width = 800, height = 600)
plot(beta_all, colMeans(R_all)*250, pch = 16, col = "red", main = "Security Market Line (SML)")
abline(a = 0.03, b = (mean(Rm)*250 - 0.03), col = "blue")
text(beta_all, colMeans(R_all)*250, labels = names(beta_all), pos = 4)
dev.off()
