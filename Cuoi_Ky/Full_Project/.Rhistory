# 1. Biểu đồ Barplot so sánh rủi ro (SD) của 5 ngành
# Mục tiêu: Minh chứng cho tính đa dạng hóa của danh mục
png("Comparison_Risk.png", width = 800, height = 600)
barplot(sd_v * sqrt(250), # Chuẩn hóa theo năm cho dễ nhìn
col = c("blue", "green", "red", "orange", "purple"),
main = "So sánh Rủi ro (Độ lệch chuẩn năm) giữa các mã",
ylab = "Volatility (Annualized)",
las = 1)
